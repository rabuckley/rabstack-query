<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RabstackQuery.Example.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:RabstackQuery.Example.Maui.Pages"
    Title="RabStack Task Board">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="tab_dashboard.png"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="DashboardPage" />

        <ShellContent
            Title="Projects"
            Icon="tab_projects.png"
            ContentTemplate="{DataTemplate pages:ProjectListPage}"
            Route="ProjectListPage" />

        <ShellContent
            Title="Settings"
            Icon="tab_settings.png"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
