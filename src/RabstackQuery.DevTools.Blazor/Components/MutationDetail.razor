@* Mutation detail panel — sticky section headers, status badge, DataExplorer for
   variables/data (no action buttons, matching TanStack Query DevTools layout) *@

<div class="rq-detail">
    <div class="rq-detail__body">
        @* ── Mutation Details ──────────────────────────── *@
        <div class="rq-detail__section">
            <div class="rq-detail__section-header">Mutation Details</div>
            <div class="rq-detail__section-body">
                @if (Item.MutationKeyDisplay is not null)
                {
                    <pre class="rq-detail__key">@Item.MutationKeyDisplay</pre>
                }
                else
                {
                    <div class="rq-detail__no-key">No mutation key found</div>
                }

                <div class="rq-detail__meta">
                    <span class="rq-detail__status-badge"
                          style="border-color: @Item.StatusColorHex; color: @Item.StatusColorHex;">
                        @Item.StatusLabel
                    </span>
                </div>

                @if (Item.SubmittedAt > 0)
                {
                    <div class="rq-detail__info">
                        <span class="rq-detail__info-label">Submitted At:</span>
                        <span>@DateTimeOffset.FromUnixTimeMilliseconds(Item.SubmittedAt).ToLocalTime().ToString("T")</span>
                    </div>
                }
            </div>
        </div>

        @* ── Variables ─────────────────────────────────── *@
        @if (Item.VariablesDisplay is not null)
        {
            <div class="rq-detail__section">
                <div class="rq-detail__section-header">Variables Details</div>
                <div class="rq-detail__section-body">
                    <DataExplorer Data="@Item.VariablesDisplay" Label="Variables" DefaultExpanded="true" />
                </div>
            </div>
        }

        @* ── Data Explorer ─────────────────────────────── *@
        <div class="rq-detail__section">
            <div class="rq-detail__section-header">Data Explorer</div>
            <div class="rq-detail__section-body">
                <DataExplorer Data="@Item.DataDisplay" Label="Data" DefaultExpanded="true" />
            </div>
        </div>

        @* ── Error ─────────────────────────────────────── *@
        @if (Item.ErrorDisplay is not null)
        {
            <div class="rq-detail__section rq-detail__section--error">
                <div class="rq-detail__section-header">Error</div>
                <div class="rq-detail__section-body">
                    <pre class="rq-detail__error">@Item.ErrorDisplay</pre>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public required MutationListItem Item { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
