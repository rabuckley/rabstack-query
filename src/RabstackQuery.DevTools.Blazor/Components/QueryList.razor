@* Query list rows — colored observer count badge on left, query key in monospace (matches TanStack layout) *@

@if (Items.Count == 0)
{
    <div class="rq-empty">No queries in the cache</div>
}
else
{
    @foreach (var item in Items)
    {
        <button class="rq-row @(item.QueryHash == SelectedHash ? "rq-row--selected" : "")"
                @onclick="() => OnSelect.InvokeAsync(item)">
            <span class="rq-row__badge" style="background-color: @item.StatusColorHex;">
                @item.ObserverCount
            </span>
            <code class="rq-row__hash">@item.QueryKeyDisplay</code>
            @if (item.IsDisabled)
            {
                <span class="rq-row__tag rq-row__tag--disabled">disabled</span>
            }
        </button>
    }
}

@code {
    [Parameter] public required List<QueryListItem> Items { get; set; }
    [Parameter] public string? SelectedHash { get; set; }
    [Parameter] public EventCallback<QueryListItem> OnSelect { get; set; }
}
