@if (Items.Count == 0)
{
    <div class="rq-empty">No queries in the cache</div>
}
else
{
    @foreach (var item in Items)
    {
        <div class="rq-row @(item.QueryHash == SelectedHash ? "rq-row--selected" : "")"
             @onclick="() => OnSelect.InvokeAsync(item)">
            <div class="rq-row__bar" style="background: @item.StatusColorHex;"></div>
            <div class="rq-row__content">
                <div class="rq-row__key">@item.QueryKeyDisplay</div>
                <div class="rq-row__meta">
                    <span style="color: @item.StatusColorHex;">@item.StatusLabel</span>
                    <span class="rq-row__hash">@item.QueryHash</span>
                </div>
            </div>
            <div class="rq-row__observers">@item.ObserverCount obs</div>
        </div>
    }
}

@code {
    [Parameter] public required List<QueryListItem> Items { get; set; }
    [Parameter] public string? SelectedHash { get; set; }
    [Parameter] public EventCallback<QueryListItem> OnSelect { get; set; }
}
