@* Query detail panel — sticky section headers, status badge, actions with colored dots,
   and DataExplorer tree view (matches TanStack Query DevTools layout) *@

<div class="rq-detail">
    <div class="rq-detail__body">
        @* ── Query Details ─────────────────────────────── *@
        <div class="rq-detail__section">
            <div class="rq-detail__section-header">Query Details</div>
            <div class="rq-detail__section-body">
                <pre class="rq-detail__key">@Item.QueryKeyDisplay</pre>

                <div class="rq-detail__meta">
                    <span class="rq-detail__status-badge"
                          style="border-color: @Item.StatusColorHex; color: @Item.StatusColorHex;">
                        @Item.StatusLabel
                    </span>
                </div>

                <div class="rq-detail__info">
                    <span class="rq-detail__info-label">Observers:</span>
                    <span>@Item.ObserverCount</span>
                </div>

                <div class="rq-detail__info">
                    <span class="rq-detail__info-label">Last Updated:</span>
                    <span>@FormatRelativeTime(Item.DataUpdatedAt)</span>
                </div>
            </div>
        </div>

        @* ── Actions ───────────────────────────────────── *@
        <div class="rq-detail__section">
            <div class="rq-detail__section-header">Actions</div>
            <div class="rq-detail__section-body">
                @{
                    var isFetching = Item.DisplayStatus is QueryDisplayStatus.Fetching;
                    var isPending = Item.Status is QueryStatus.Pending;
                }
                <div class="rq-detail__actions">
                    <button class="rq-action" disabled="@(isFetching || _isRefetching)" @onclick="HandleRefetch">
                        <span class="rq-action__dot" style="background: @DevToolsColorValues.Fetching;"></span>
                        Refetch
                    </button>
                    <button class="rq-action" disabled="@isPending" @onclick="HandleInvalidate">
                        <span class="rq-action__dot" style="background: @DevToolsColorValues.Stale;"></span>
                        Invalidate
                    </button>
                    <button class="rq-action" disabled="@isPending" @onclick="HandleReset">
                        <span class="rq-action__dot" style="background: @DevToolsColorValues.Inactive;"></span>
                        Reset
                    </button>
                    <button class="rq-action rq-action--danger" disabled="@isFetching" @onclick="HandleRemove">
                        <span class="rq-action__dot" style="background: @DevToolsColorValues.Error;"></span>
                        Remove
                    </button>
                    @{
                        var isTriggeredLoading = Item.IsDevToolsTriggered && Item.Status is QueryStatus.Pending;
                        var isTriggeredError = Item.IsDevToolsTriggered && Item.Status is QueryStatus.Errored;
                    }
                    <button class="rq-action" disabled="@(isPending && !isTriggeredLoading)" @onclick="HandleTriggerLoading">
                        <span class="rq-action__dot" style="background: @DevToolsColorValues.Fetching;"></span>
                        @(isTriggeredLoading ? "Restore Loading" : "Trigger Loading")
                    </button>
                    <button class="rq-action" disabled="@(isPending && !isTriggeredError)" @onclick="HandleTriggerError">
                        <span class="rq-action__dot" style="background: @DevToolsColorValues.Error;"></span>
                        @(isTriggeredError ? "Restore Error" : "Trigger Error")
                    </button>
                </div>
            </div>
        </div>

        @* ── Data Explorer ─────────────────────────────── *@
        <div class="rq-detail__section">
            <div class="rq-detail__section-header">Data Explorer</div>
            <div class="rq-detail__section-body">
                <DataExplorer Data="@Item.DataDisplay" Label="Data" DefaultExpanded="true" />
            </div>
        </div>

        @* ── Error ─────────────────────────────────────── *@
        @if (Item.ErrorDisplay is not null)
        {
            <div class="rq-detail__section rq-detail__section--error">
                <div class="rq-detail__section-header">Error</div>
                <div class="rq-detail__section-body">
                    <pre class="rq-detail__error">@Item.ErrorDisplay</pre>
                </div>
            </div>
        }
    </div>
</div>
