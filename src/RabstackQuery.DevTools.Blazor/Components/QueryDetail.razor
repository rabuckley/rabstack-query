@* Detail panel for a single query with action buttons *@

<div class="rq-detail">
    <div class="rq-detail__header">
        <span class="rq-detail__title">Query Detail</span>
        <button class="rq-detail__close" @onclick="OnClose">✕</button>
    </div>

    <div class="rq-detail__body">
        @* Identity *@
        <div class="rq-section">
            <div class="rq-section__title">Query Key</div>
            <div class="rq-section__value rq-mono">@Item.QueryKeyDisplay</div>
        </div>

        <div class="rq-section">
            <div class="rq-section__title">Query Hash</div>
            <div class="rq-section__value rq-mono">@Item.QueryHash</div>
        </div>

        @* Status grid *@
        <div class="rq-card">
            <div class="rq-grid">
                <div class="rq-field">
                    <span class="rq-field__label">Status</span>
                    <span class="rq-field__value" style="color: @Item.StatusColorHex; font-weight: 600;">@Item.StatusLabel</span>
                </div>
                <div class="rq-field">
                    <span class="rq-field__label">Fetch Status</span>
                    <span class="rq-field__value">@Item.FetchStatus</span>
                </div>
                <div class="rq-field">
                    <span class="rq-field__label">Observers</span>
                    <span class="rq-field__value">@Item.ObserverCount</span>
                </div>
                <div class="rq-field">
                    <span class="rq-field__label">Last Updated</span>
                    <span class="rq-field__value">@FormatRelativeTime(Item.DataUpdatedAt)</span>
                </div>
                <div class="rq-field">
                    <span class="rq-field__label">Invalidated</span>
                    <span class="rq-field__value">@(Item.IsInvalidated ? "Yes" : "No")</span>
                </div>
                <div class="rq-field">
                    <span class="rq-field__label">Failure Count</span>
                    <span class="rq-field__value">@Item.FetchFailureCount</span>
                </div>
            </div>
        </div>

        @* Data *@
        <div class="rq-section">
            <div class="rq-section__title">Data</div>
            <div class="rq-section__value rq-mono rq-section__value--scrollable">@FormatDataDisplay(Item.DataDisplay)</div>
        </div>

        @* Error *@
        @if (Item.ErrorDisplay is not null)
        {
            <div class="rq-section rq-section--error">
                <div class="rq-section__title">Error</div>
                <div class="rq-section__value rq-mono rq-section__value--scrollable">@Item.ErrorDisplay</div>
            </div>
        }

        @* Actions *@
        <div class="rq-actions">
            <button class="rq-action-btn" disabled="@_isRefetching" @onclick="HandleRefetch">
                @(_isRefetching ? "Refetching..." : "Refetch")
            </button>
            <button class="rq-action-btn" @onclick="HandleInvalidate">Invalidate</button>
            <button class="rq-action-btn" @onclick="HandleReset">Reset</button>
            <button class="rq-action-btn rq-action-btn--danger" @onclick="HandleRemove">Remove</button>
        </div>
    </div>
</div>
