@if (Items.Count == 0)
{
    <div class="rq-empty">No mutations in the cache</div>
}
else
{
    @foreach (var item in Items)
    {
        <div class="rq-row @(item.MutationId == SelectedId ? "rq-row--selected" : "")"
             @onclick="() => OnSelect.InvokeAsync(item)">
            <div class="rq-row__bar" style="background: @item.StatusColorHex;"></div>
            <div class="rq-row__content">
                <div class="rq-row__key">Mutation #@item.MutationId</div>
                <div class="rq-row__meta">
                    <span style="color: @item.StatusColorHex;">@item.StatusLabel</span>
                    @if (item.MutationKeyDisplay is not null)
                    {
                        <span class="rq-row__hash">@item.MutationKeyDisplay</span>
                    }
                </div>
            </div>
            @if (item.HasObservers)
            {
                <div class="rq-row__observers">observed</div>
            }
        </div>
    }
}

@code {
    [Parameter] public required List<MutationListItem> Items { get; set; }
    [Parameter] public int? SelectedId { get; set; }
    [Parameter] public EventCallback<MutationListItem> OnSelect { get; set; }
}
